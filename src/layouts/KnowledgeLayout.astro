---
import BaseLayout from "./BaseLayout.astro";

const { frontmatter, headings = [] } = Astro.props;
const tocHeadings = headings.filter((heading) => heading.depth === 2);
---

<BaseLayout title={frontmatter.title} description={frontmatter.description}>
  <main class="knowledge-page">
    <nav class="breadcrumb" aria-label="Huvudnavigation">
      <a href="/">Start</a>
      <span aria-hidden="true">/</span>
      <span>{frontmatter.navLabel ?? frontmatter.title}</span>
    </nav>

    <header class="knowledge-hero">
      <p class="eyebrow">{frontmatter.kicker ?? "Kunskapsområde"}</p>
      <h1>{frontmatter.title}</h1>
      {frontmatter.ingress && <p class="lead">{frontmatter.ingress}</p>}
    </header>

    <div class="knowledge-layout">
      <aside class="toc-panel" aria-label="Innehållsförteckning">
        <details open>
          <summary>Innehåll</summary>
          <ol>
            {
              tocHeadings.map((heading) => (
                <li>
                  <a href={`#${heading.slug}`}>{heading.text}</a>
                </li>
              ))
            }
          </ol>
        </details>
      </aside>

      <article class="knowledge-content">
        <slot />
      </article>
    </div>
  </main>
</BaseLayout>

<script>
  const links = Array.from(document.querySelectorAll(".toc-panel a"));
  const sections = links
    .map((link) => {
      const id = link.getAttribute("href")?.slice(1);
      const section = id ? document.getElementById(id) : null;
      return section ? { link, section } : null;
    })
    .filter(Boolean);

  const observer = new IntersectionObserver(
    (entries) => {
      const visible = entries
        .filter((entry) => entry.isIntersecting)
        .sort((a, b) => b.intersectionRatio - a.intersectionRatio)[0];

      if (!visible) return;

      links.forEach((link) => link.removeAttribute("aria-current"));
      const active = sections.find((item) => item?.section === visible.target);
      active?.link.setAttribute("aria-current", "true");
    },
    {
      rootMargin: "-18% 0px -62% 0px",
      threshold: [0.1, 0.3, 0.6],
    },
  );

  sections.forEach((item) => item && observer.observe(item.section));
</script>

<style>
  .knowledge-page {
    width: min(1180px, calc(100% - 32px));
    margin: 0 auto;
    padding: 28px 0 72px;
  }

  .breadcrumb {
    display: flex;
    gap: 10px;
    align-items: center;
    color: var(--muted);
    font-size: 0.95rem;
  }

  .breadcrumb a {
    color: var(--accent-dark);
    font-weight: 750;
    text-decoration: none;
  }

  .knowledge-hero {
    max-width: 920px;
    padding: 72px 0 42px;
  }

  .eyebrow {
    margin: 0 0 12px;
    color: var(--accent);
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  h1 {
    max-width: 900px;
    margin: 0 0 20px;
    font-family: Georgia, "Times New Roman", serif;
    font-size: clamp(3rem, 8vw, 6.5rem);
    line-height: 0.95;
  }

  .lead {
    max-width: 820px;
    margin: 0;
    color: var(--muted);
    font-size: clamp(1.1rem, 2vw, 1.35rem);
    line-height: 1.62;
  }

  .knowledge-layout {
    display: grid;
    grid-template-columns: 280px minmax(0, 1fr);
    gap: 34px;
    align-items: start;
  }

  .toc-panel {
    position: sticky;
    top: 24px;
    min-width: 0;
    padding: 18px 18px 20px;
    border: 1px solid var(--line);
    border-radius: 8px;
    background: color-mix(in srgb, var(--panel) 88%, transparent);
  }

  .toc-panel summary {
    cursor: pointer;
    color: var(--accent);
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    list-style-position: outside;
    text-transform: uppercase;
  }

  .toc-panel ol {
    display: grid;
    gap: 10px;
    margin: 16px 0 0;
    padding-left: 20px;
  }

  .toc-panel a {
    color: var(--ink);
    line-height: 1.35;
    text-decoration-color: color-mix(in srgb, var(--accent) 35%, transparent);
    text-underline-offset: 3px;
  }

  .toc-panel a[aria-current="true"] {
    color: var(--accent-dark);
    font-weight: 800;
    text-decoration-thickness: 2px;
  }

  .knowledge-content {
    min-width: 0;
    max-width: 820px;
    padding: 30px;
    border: 1px solid var(--line);
    border-radius: 8px;
    background: var(--panel);
    box-shadow: var(--shadow);
  }

  .knowledge-content :global(h2) {
    margin: 48px 0 14px;
    padding-top: 4px;
    font-family: Georgia, "Times New Roman", serif;
    font-size: clamp(1.9rem, 3vw, 2.75rem);
    line-height: 1.08;
    scroll-margin-top: 28px;
  }

  .knowledge-content :global(h2:first-child) {
    margin-top: 0;
  }

  .knowledge-content :global(h3) {
    margin: 28px 0 8px;
    font-size: 1.1rem;
  }

  .knowledge-content :global(p),
  .knowledge-content :global(li),
  .knowledge-content :global(td) {
    color: var(--muted);
    line-height: 1.75;
  }

  .knowledge-content :global(p) {
    margin: 0 0 16px;
  }

  .knowledge-content :global(sup) {
    font-size: 0.75em;
    line-height: 0;
  }

  .knowledge-content :global(sup a) {
    color: var(--accent-dark);
    font-weight: 800;
    text-decoration: none;
  }

  .knowledge-content :global(ul) {
    display: grid;
    gap: 8px;
    margin: 0 0 22px;
    padding-left: 22px;
  }

  .knowledge-content :global(table) {
    width: 100%;
    min-width: 720px;
    border-collapse: collapse;
  }

  .knowledge-content :global(.table-scroll) {
    max-width: 100%;
    margin: 20px 0 28px;
    overflow-x: auto;
  }

  .knowledge-content :global(th),
  .knowledge-content :global(td) {
    padding: 14px;
    border-bottom: 1px solid var(--line);
    text-align: left;
    vertical-align: top;
  }

  .knowledge-content :global(th) {
    color: var(--ink);
  }

  .knowledge-content :global(.future-grid) {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 14px;
    margin-top: 20px;
  }

  .knowledge-content :global(.future-grid > li) {
    padding: 16px;
    border: 1px solid var(--line);
    border-radius: 8px;
    background: color-mix(in srgb, var(--paper) 55%, var(--panel));
    list-style: none;
  }

  .knowledge-content :global(.future-grid strong) {
    display: block;
    margin-bottom: 6px;
    color: var(--ink);
  }

  .knowledge-content :global(.footnotes) {
    margin-top: 52px;
    padding-top: 20px;
    border-top: 1px solid var(--line);
    font-size: 0.95rem;
  }

  .knowledge-content :global(.footnotes h2) {
    margin-top: 0;
    font-size: 1.4rem;
  }

  .knowledge-content :global(.footnotes ol) {
    display: grid;
    gap: 10px;
    padding-left: 22px;
  }

  @media (max-width: 860px) {
    .knowledge-page {
      width: min(100% - 24px, 1180px);
    }

    .knowledge-hero {
      padding: 52px 0 30px;
    }

    .lead {
      font-size: 1.22rem;
      line-height: 1.65;
    }

    .knowledge-layout {
      grid-template-columns: 1fr;
      gap: 18px;
    }

    .toc-panel {
      position: static;
      font-size: 1.04rem;
    }

    .toc-panel details:not([open]) {
      padding-bottom: 0;
    }

    .knowledge-content {
      padding: 22px;
    }

    .knowledge-content :global(p),
    .knowledge-content :global(li),
    .knowledge-content :global(td) {
      font-size: 1.18rem;
      line-height: 1.72;
    }

    .knowledge-content :global(h2) {
      font-size: clamp(2.08rem, 8.5vw, 2.55rem);
    }

    .knowledge-content :global(h3) {
      font-size: 1.26rem;
    }

    .knowledge-content :global(.future-grid) {
      grid-template-columns: 1fr;
    }
  }
</style>
