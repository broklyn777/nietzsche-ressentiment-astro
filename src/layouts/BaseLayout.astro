---
const { title, description } = Astro.props;
---

<!doctype html>
<html lang="sv">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <script is:inline>
      const prefersDark = window.matchMedia("(prefers-color-scheme: dark)").matches;
      let storedTheme;

      try {
        storedTheme = localStorage.getItem("theme");
      } catch {
        storedTheme = null;
      }

      document.documentElement.dataset.theme =
        storedTheme ?? (prefersDark ? "dark" : "light");
    </script>
    <title>{title}</title>
  </head>
  <body>
    <button class="theme-toggle" type="button" aria-label="Byt till nattläge">
      <span class="theme-toggle__icon" aria-hidden="true">☾</span>
      <span class="theme-toggle__text">Natt</span>
    </button>
    <slot />
    <script is:inline>
      const themeButton = document.querySelector(".theme-toggle");
      const themeIcon = document.querySelector(".theme-toggle__icon");
      const themeText = document.querySelector(".theme-toggle__text");

      function updateThemeButton(theme) {
        const isDark = theme === "dark";
        themeButton?.setAttribute(
          "aria-label",
          isDark ? "Byt till dagläge" : "Byt till nattläge",
        );
        if (themeIcon) themeIcon.textContent = isDark ? "☼" : "☾";
        if (themeText) themeText.textContent = isDark ? "Dag" : "Natt";
      }

      updateThemeButton(document.documentElement.dataset.theme);

      themeButton?.addEventListener("click", () => {
        const currentTheme = document.documentElement.dataset.theme;
        const nextTheme = currentTheme === "dark" ? "light" : "dark";
        document.documentElement.dataset.theme = nextTheme;
        try {
          localStorage.setItem("theme", nextTheme);
        } catch {
          // Theme still changes for this page load if storage is unavailable.
        }
        updateThemeButton(nextTheme);
      });
    </script>
  </body>
</html>

<style is:global>
  :root {
    color-scheme: light dark;
    --ink: #1f1d1a;
    --muted: #6f665c;
    --paper: #f7f1e7;
    --panel: #fffaf0;
    --line: #d8caba;
    --accent: #9b4a31;
    --accent-dark: #64301f;
    --shadow: 0 18px 55px rgba(44, 31, 21, 0.12);
    font-family:
      Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI",
      sans-serif;
  }

  :root[data-theme="dark"] {
    --ink: #f3eadf;
    --muted: #c8baaa;
    --paper: #16120f;
    --panel: #211a15;
    --line: #3b3028;
    --accent: #d9896d;
    --accent-dark: #f0b7a0;
    --shadow: 0 18px 55px rgba(0, 0, 0, 0.34);
  }

  :root[data-theme="light"] {
    color-scheme: light;
  }

  :root[data-theme="dark"] {
    color-scheme: dark;
  }

  * {
    box-sizing: border-box;
  }

  body {
    margin: 0;
    min-height: 100vh;
    background:
      linear-gradient(115deg, rgba(143, 45, 28, 0.08), transparent 45%),
      var(--paper);
    color: var(--ink);
  }

  a {
    color: inherit;
  }

  .theme-toggle {
    position: fixed;
    z-index: 20;
    top: 16px;
    right: 16px;
    display: inline-flex;
    gap: 8px;
    align-items: center;
    min-height: 38px;
    padding: 0 12px;
    border: 1px solid var(--line);
    border-radius: 999px;
    background: color-mix(in srgb, var(--panel) 88%, transparent);
    box-shadow: 0 10px 28px rgba(44, 31, 21, 0.12);
    color: var(--ink);
    cursor: pointer;
    font: inherit;
    font-size: 0.9rem;
    font-weight: 750;
  }

  .theme-toggle:focus-visible {
    outline: 3px solid color-mix(in srgb, var(--accent) 55%, transparent);
    outline-offset: 3px;
  }

  @media (max-width: 1200px) {
    .theme-toggle {
      top: auto;
      right: 14px;
      bottom: 14px;
      min-height: 46px;
      padding: 0 16px;
      background: var(--panel);
      box-shadow: 0 12px 32px rgba(0, 0, 0, 0.22);
      font-size: 1rem;
    }
  }
</style>
