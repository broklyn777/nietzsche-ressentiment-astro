---
const { title, description } = Astro.props;
---

<!doctype html>
<html lang="sv">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>

<style is:global>
  :root {
    color-scheme: light dark;
    --ink: #191714;
    --muted: #665f56;
    --paper: #fbf7ef;
    --panel: #fffdf8;
    --line: #ded3c2;
    --accent: #8f2d1c;
    --accent-dark: #5f1c12;
    --shadow: 0 18px 55px rgba(45, 30, 16, 0.13);
    font-family:
      Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI",
      sans-serif;
  }

  @media (prefers-color-scheme: dark) {
    :root {
      --ink: #f5efe5;
      --muted: #c8bcae;
      --paper: #17130f;
      --panel: #211b16;
      --line: #3d3128;
      --accent: #e07d65;
      --accent-dark: #f0b29f;
      --shadow: 0 18px 55px rgba(0, 0, 0, 0.32);
    }
  }

  * {
    box-sizing: border-box;
  }

  body {
    margin: 0;
    min-height: 100vh;
    background:
      linear-gradient(115deg, rgba(143, 45, 28, 0.08), transparent 45%),
      var(--paper);
    color: var(--ink);
  }

  a {
    color: inherit;
  }
</style>
