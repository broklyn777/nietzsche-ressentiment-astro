---
interface Props {
  title: string;
  text: string;
}

const { title, text } = Astro.props;
---

<article>
  <h3>{title}</h3>
  <p>{text}</p>
</article>

<style>
  article {
    padding: 22px;
    border: 1px solid var(--line);
    border-radius: 8px;
    background: rgba(255, 253, 248, 0.82);
  }

  h3 {
    margin: 0 0 10px;
    font-size: 1.2rem;
  }

  p {
    margin: 0;
    color: var(--muted);
    line-height: 1.65;
  }
</style>
