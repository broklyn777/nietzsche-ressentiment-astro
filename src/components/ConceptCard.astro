---
interface Props {
  title: string;
  text: string;
}

const { title, text } = Astro.props;
---

<article>
  <h3>{title}</h3>
  <p>{text}</p>
</article>

<style>
  article {
    padding: 22px;
    border: 1px solid var(--line);
    border-radius: 8px;
    background: color-mix(in srgb, var(--panel) 86%, var(--paper));
    box-shadow: 0 10px 28px rgba(44, 31, 21, 0.08);
  }

  h3 {
    margin: 0 0 10px;
    color: var(--ink);
    font-size: 1.2rem;
  }

  p {
    margin: 0;
    color: var(--muted);
    line-height: 1.65;
  }

  :global(:root[data-theme="dark"]) article {
    background: color-mix(in srgb, var(--panel) 88%, #000 12%);
    box-shadow: none;
  }
</style>
